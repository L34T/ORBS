<Window x:Class="SWTORCombatParser.Views.Overlay.Timeline.TimelineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Height="220" Width="600" AllowsTransparency="True" ResizeMode="NoResize" Title="Timeline Overlay" Background="{x:Null}" WindowStyle="None" Topmost="True" MouseLeave="Window_MouseLeave">
    
    <Grid>
        <Border x:Name="BackgroundArea" PreviewMouseLeftButtonDown="DragWindow" MouseEnter="Border_MouseEnter" MouseLeave="Grid_MouseLeave"
                IsHitTestVisible="{Binding OverlaysMoveable}" Background="Black" Opacity="0.45" CornerRadius="5" BorderBrush="DimGray" BorderThickness="1">
        </Border>
        
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header (only visible when moveable) -->
            <Grid Grid.Row="0" Visibility="{Binding OverlaysMoveable, Converter={StaticResource BooleanToVisibiityConverter}}" MouseLeftButtonDown="DragWindow" MouseEnter="Border_MouseEnter" MouseLeave="Grid_MouseLeave">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>
                <TextBlock FontFamily="{StaticResource MainFont}" Foreground="WhiteSmoke" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0" Text="Timeline Overlay"/>
                <Button Grid.Column="1" Style="{StaticResource RoundCornerButton}" Background="#c96161" Width="18" Height="18" Padding="0" Content="X" FontSize="8" FontWeight="Bold" Click="Button_Click"/>
            </Grid>
            
            <TextBlock Grid.Row="1" FontSize="14" x:Name="EncounterName" FontFamily="{StaticResource MainFont}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="0,5,0,5"></TextBlock>
            
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0" Foreground="WhiteSmoke" FontSize="11" Text="Start"></TextBlock>
                
                <Grid Grid.Column="1" VerticalAlignment="Stretch">
                    <Rectangle Height="2" Fill="LightGray" VerticalAlignment="Center" HorizontalAlignment="Stretch" />
                    <Canvas x:Name="TimelineCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <!-- Timeline bars will be dynamically rendered here -->
                    </Canvas>
                </Grid>
                
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="WhiteSmoke" FontSize="11" Text="Encounter"></TextBlock>
                <TextBlock Grid.Column="1" x:Name="DurationInfo" HorizontalAlignment="Center" VerticalAlignment="Bottom" Foreground="WhiteSmoke" FontSize="11" FontStyle="Italic" Margin="0,0,0,2"></TextBlock>
            </Grid>
            
            <!-- Resizing thumb -->
            <Thumb Visibility="{Binding OverlaysMoveable, Converter={StaticResource OverlayMoveableToVisibilityConverter}}" Grid.Row="1" Grid.RowSpan="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Style="{StaticResource LampadaThumbStyle}" 
                   MouseEnter="Thumb_MouseEnter" MouseLeave="Grid_MouseLeave" PreviewMouseLeftButtonUp="UpdateDefaults" DragDelta="Thumb_DragDelta"></Thumb>
        </Grid>
    </Grid>
</Window>
