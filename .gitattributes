# Define default behavior to automatically normalize line endings
* text=auto

# Source code files (C#)
*.cs text diff=csharp eol=crlf

# Markup and layout files (WPF XAML / Avalonia AXAML)
*.xaml text eol=crlf
*.axaml text eol=crlf

# Solution and Project files
*.sln text eol=crlf
*.csproj text eol=crlf
*.vbproj text eol=crlf
*.fsproj text eol=crlf
*.wapproj text eol=crlf
*.wixproj text eol=crlf

# Build and configuration files
*.config text eol=crlf
*.json text eol=crlf
*.xml text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf
*.settings text eol=crlf
*.pubxml text eol=crlf

# Documentation and text files
*.md text eol=lf
*.txt text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.dll binary
*.exe binary

# Large File Storage (LFS)
*.msi filter=lfs diff=lfs merge=lfs -text
